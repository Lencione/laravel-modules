{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "lencione/laravel-modules",
    "description": "Gerador de módulos para projetos Laravel com estrutura padronizada.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "modules",
        "scaffold",
        "generator",
        "structure"
    ],
    "homepage": "https://github.com/Lencione/laravel-modules",
    "support": {
        "issues": "https://github.com/Lencione/laravel-modules/issues",
        "source": "https://github.com/Lencione/laravel-modules"
    },
    "authors": [
        {
            "name": "Lencione",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Lencione\\LaravelModules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lencione\\LaravelModules\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lencione\\LaravelModules\\LaravelModulesServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
